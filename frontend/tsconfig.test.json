{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "outDir": "../.tmp/roocode-frontend-tests",
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "src/types/apple-health.ts",
    "src/types/pharmacology.ts",
    "src/utils/date.ts",
    "src/utils/aggregation.ts",
    "src/utils/pharmacokinetics.ts",
    "src/utils/medication-bridge.ts",
    "src/utils/statistics.ts",
    "src/utils/personal-baselines.ts",
    "src/utils/interp-policy.ts",
    "src/utils/sleep-debt.ts",
    "src/utils/recovery-score.ts",
    "src/utils/autonomic-balance.ts",
    "src/utils/forecast-payload-enrichment.ts",
    "src/utils/health-policies.ts",
    "src/utils/heart-rate-reserve.ts",
    "src/utils/hrv-variability.ts",
    "src/utils/chronotropic-response.ts",
    "src/utils/driver-ranking.ts",
    "src/utils/insights-narrative.ts",
    "tests/**/*.ts"
  ]
}
